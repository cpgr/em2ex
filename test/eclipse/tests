missing_specgrid:
  filename: missing_specgrid.grdecl
  type: exception
  expected_error: No SPECGRID data found

missing_coord:
  filename: missing_coord.grdecl
  type: exception
  expected_error: No COORD data found

missing_zcorn:
  filename: missing_zcorn.grdecl
  type: exception
  expected_error: No ZCORN data found

incorrect_coord:
  filename: incorrect_coord.grdecl
  type: exception
  expected_error: The number of COORD entries read is not correct

incorrect_zcorn:
  filename: incorrect_zcorn.grdecl
  type: exception
  expected_error: The number of ZCORN entries read is not correct

incorrect_property:
  filename: incorrect_property.grdecl
  type: exception
  expected_error: The number of PORO entries read is not correct

refine_xy_zero:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --refine-xy 0 2
  expected_error: expected a positive integer (>= 1)

refine_xy_negative:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --refine-xy 2 -3
  expected_error: expected a positive integer (>= 1)

refine_xy_non_integer:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --refine-xy 1.5 2
  expected_error: expected a positive integer

refine_xy_garbage:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --refine-xy foo 2
  expected_error: expected a positive integer

extract_i_out_of_bounds:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --extract-i 1 99
  expected_error: --extract-i range 1..99 is out of bounds for the x-axis (NX=3 in SPECGRID)

extract_j_inverted:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --extract-j 3 1
  expected_error: --extract-j requires LO <= HI, got 3 > 1

extract_k_zero:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --extract-k 0 2
  expected_error: expected a positive integer (>= 1)

extract_i_non_integer:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --extract-i 1.5 2
  expected_error: expected a positive integer

extra_keywords_bad:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --extra-keywords FOO-BAR --
  expected_error: expected a short alphanumeric Eclipse keyword

extra_keywords_typo:
  filename: simple_cube.grdecl
  type: exception
  cli_args: --extra-keywords PVTNUMM --
  expected_error: --extra-keywords requested PVTNUMM but the keyword was not found
